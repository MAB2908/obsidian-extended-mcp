# Obsidian Extended MCP v0.3.4 — production-ready configuration template
# Copy this file to .env and fill in the values for your environment.
# Environment variables override mcp-config.yaml.

# =============================================================================
# 1. REQUIRED: Obsidian vault
# =============================================================================
OBSIDIAN_VAULT_PATH=./vault

# =============================================================================
# 2. LLM PROVIDER (pick one preset and fill in the blanks)
# =============================================================================

# --- Preset A: Local / privacy-first (Ollama) ---
DEFAULT_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Preset B: OpenAI ---
# DEFAULT_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Preset C: Anthropic ---
# DEFAULT_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# --- Preset D: Mixed (Ollama embeddings + OpenAI chat) ---
# DEFAULT_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text

# LLM cache & retry tuning
LLM_MAX_CACHE_SIZE=1000
LLM_CACHE_TTL_MS=3600000
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY_MS=1000

# =============================================================================
# 3. SEMANTIC SEARCH (SQLite FTS5 + optional vector embeddings)
# =============================================================================

# Set to true if you configured an embedding provider above.
# If false, semantic_search falls back to FTS5 keyword search.
SEMANTIC_ENABLED=false

# OpenAI embedding model (used when DEFAULT_LLM_PROVIDER=openai or mixed)
EMBED_MODEL=text-embedding-3-small

# Graph / search tuning
RRF_K=60
GRAPH_PAGERANK_ITERATIONS=20
GRAPH_PAGERANK_DAMPING=0.85
GRAPH_COMMUNITY_MAX_PASSES=10
GRAPH_PATH_MAX_DEPTH=5

# Indexer: lower = more responsive, higher = less I/O
INDEXER_DEBOUNCE_MS=1000

# Result limits
SEMANTIC_SEARCH_LIMIT=10
SEMANTIC_RAG_TOP_K=5

# =============================================================================
# 4. FILESYSTEM TUNING
# =============================================================================
FS_TRASH_DIR=.trash
FS_BACKUP_DIR=.mcp-cache/backups
FS_MAX_BACKUPS=50
FS_BACKUP_BEFORE_WRITE=true
FS_MAX_NOTE_SIZE=10485760
FILE_TEXT_EXTENSIONS=md,txt,json,canvas,yml,yaml

# =============================================================================
# 5. OBSIDIAN BRIDGES (CLI and/or Local REST API plugin)
# =============================================================================

# Optional: path to obsidian-cli binary. If unset, CLI tools fall back to graph/filesystem.
OBSIDIAN_CLI_PATH=

# Local REST API plugin base URL (Obsidian plugin "Local REST API")
REST_API_URL=http://localhost:27123
REST_API_TOKEN=

# =============================================================================
# 6. TRANSPORT
# =============================================================================

# Bearer token used for stdio auth wrapper AND required when HTTP is enabled.
# Generate with: openssl rand -hex 32
MCP_AUTH_TOKEN=

# Streamable HTTP transport (default: stdio only)
MCP_HTTP_ENABLED=false
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8787
MCP_HTTP_PATH=/mcp
MCP_HTTP_CORS_ORIGINS=
MCP_STDIO_DISABLED=false

# =============================================================================
# 7. SECURITY POLICIES (secure-by-default)
# =============================================================================

READ_ONLY=false
ENABLE_COMMANDS=false
ENABLE_EVAL=false
ENABLE_BATCH_EDIT=false
ENABLE_DELETE=false
ENABLE_AUDIT=true

# Approval mode: auto | interactive | strict
APPROVAL_MODE=interactive

# Folder ACL (comma-separated paths)
SAFE_ZONES=raw/,sessions/
WRITE_PATHS=*
FORBIDDEN_PATHS=.git/,.obsidian/,.trash/

# Sandbox (cli_eval only)
SANDBOX_TIMEOUT_MS=5000
SANDBOX_ALLOWED_GLOBALS=app,DataviewAPI,moment,MetadataCache

# =============================================================================
# 8. AUDIT LOGGING
# =============================================================================
AUDIT_FORMAT=jsonl
AUDIT_MAX_AGE_DAYS=90
AUDIT_BATCH_SIZE=50
AUDIT_FLUSH_INTERVAL_MS=5000
AUDIT_ROTATION_MB=10
AUDIT_MAX_BUFFER_SIZE=10000

# Optional remote audit sink
AUDIT_REMOTE_URL=
AUDIT_REMOTE_TOKEN=
AUDIT_REMOTE_BATCH_SIZE=50
AUDIT_REMOTE_TIMEOUT_MS=5000
AUDIT_REMOTE_RETRY_ATTEMPTS=3

# =============================================================================
# 9. PIPELINE TUNING
# =============================================================================
PIPELINE_COMPILE_SINCE_DAYS=30
PIPELINE_MOC_AGE_DAYS=90
PIPELINE_MIN_CONFIDENCE=0.7
PIPELINE_SEEDLING_MAX_AGE_DAYS=90

# =============================================================================
# 10. AUTO-DREAMING
# =============================================================================
AUTO_DREAM_ENABLED=false
AUTO_DREAM_INTERVAL=24
AUTO_DREAM_WATCH=true
AUTO_DREAM_DEBOUNCE=5
AUTO_DREAM_DRY_RUN=false

# =============================================================================
# 11. OTHER
# =============================================================================
MULTI_VAULT=false
ENFORCE_ONTOLOGY=false
MCP_CONFIG_PATH=
