// v0.2b:
# Obsidian vault path (absolute or relative)
OBSIDIAN_VAULT_PATH=./vault

# ─── LLM Provider configuration ───
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text
OLLAMA_EMBED_MODEL=nomic-embed-text

# Default provider: openai | anthropic | ollama
DEFAULT_LLM_PROVIDER=openai

# LLM cache & retry tuning
LLM_MAX_CACHE_SIZE=1000
LLM_CACHE_TTL_MS=3600000
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY_MS=1000

# ─── Semantic search ───
SEMANTIC_ENABLED=false
EMBED_MODEL=text-embedding-3-small

# Graph / Search tuning
RRF_K=60
GRAPH_PAGERANK_ITERATIONS=20
GRAPH_PAGERANK_DAMPING=0.85
GRAPH_COMMUNITY_MAX_PASSES=10
GRAPH_PATH_MAX_DEPTH=5
INDEXER_DEBOUNCE_MS=2000
SEMANTIC_SEARCH_LIMIT=20
SEMANTIC_RAG_TOP_K=5

# ─── Filesystem tuning ───
FS_TRASH_DIR=.trash
FS_BACKUP_DIR=.mcp-cache/backups
FS_MAX_BACKUPS=20
FILE_TEXT_EXTENSIONS=md,txt

# ─── Obsidian CLI path (optional) ───
OBSIDIAN_CLI_PATH=

# ─── Local REST API (Obsidian Local REST API plugin fallback) ───
# Base URL of the Local REST API plugin. HTTPS is required when REST_API_TOKEN is set.
REST_API_URL=http://localhost:27123
# Bearer token configured in the Local REST API plugin settings.
REST_API_TOKEN=

# ─── Transport security ───
MCP_AUTH_TOKEN=

# ─── Streamable HTTP transport ───
MCP_HTTP_ENABLED=false
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8787
MCP_HTTP_PATH=/mcp
# Comma-separated list of allowed CORS origins (leave empty to disable CORS)
MCP_HTTP_CORS_ORIGINS=
# Disable stdio transport when running HTTP-only
MCP_STDIO_DISABLED=false

# ─── Multi-vault mode ───
MULTI_VAULT=false

# ─── Ontology enforcement ───
ENFORCE_ONTOLOGY=false

# ─── Operation policies ───
READ_ONLY=false
ENABLE_COMMANDS=false
# SECURITY: cli_eval runs arbitrary JS. Disabled by default.
ENABLE_EVAL=false
ENABLE_BATCH_EDIT=false
ENABLE_DELETE=false
ENABLE_AUDIT=true

# ─── Sandbox ───
SANDBOX_TIMEOUT_MS=5000
SANDBOX_ALLOWED_GLOBALS=app,DataviewAPI,moment,MetadataCache

# ─── Audit logging ───
AUDIT_FORMAT=jsonl
AUDIT_MAX_AGE_DAYS=90
AUDIT_BATCH_SIZE=100
AUDIT_FLUSH_INTERVAL_MS=5000
AUDIT_ROTATION_MB=10

# ─── Remote audit sink (optional) ───
AUDIT_REMOTE_URL=
AUDIT_REMOTE_TOKEN=
AUDIT_REMOTE_BATCH_SIZE=50
AUDIT_REMOTE_TIMEOUT_MS=5000
AUDIT_REMOTE_RETRY_ATTEMPTS=3

# ─── Folder policies (comma-separated paths) ───
SAFE_ZONES=raw/,sessions/
WRITE_PATHS=*
FORBIDDEN_PATHS=.git/,.obsidian/,.trash/

# ─── Approval mode: auto | interactive | strict ───
APPROVAL_MODE=auto

# ─── Pipeline tuning ───
# Note: hardcoded fallbacks in src/shared/config.ts are 30 / 90 / 0.7 / 90 respectively
PIPELINE_COMPILE_SINCE_DAYS=30
PIPELINE_MOC_AGE_DAYS=90
PIPELINE_MIN_CONFIDENCE=0.7
PIPELINE_SEEDLING_MAX_AGE_DAYS=90

# ─── Config file path (optional) ───
MCP_CONFIG_PATH=
